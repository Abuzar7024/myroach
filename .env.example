# MVP / local testing — set false for live Firestore (production / Vercel)
NEXT_PUBLIC_USE_MOCK_DATA=false

# Currency display
NEXT_PUBLIC_CURRENCY=INR

# Dedicated admin panel (storefront /admin redirects here)
NEXT_PUBLIC_ADMIN_PANEL_URL=https://myroach-admin.vercel.app

# Public site URL — required for email verification links in production (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://myroach.vercel.app

# Firebase (client) — copy to .env.local and fill in values from Firebase Console
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your_measurement_id

# Firebase App Check debug token (dev only — from Console → App Check → Manage debug tokens)
NEXT_PUBLIC_FIREBASE_APP_CHECK_DEBUG_TOKEN=your_app_check_debug_token_here

# reCAPTCHA v3 site key from Firebase Console → App Check → your web app (required to init App Check)
NEXT_PUBLIC_FIREBASE_APP_CHECK_RECAPTCHA_SITE_KEY=your_recaptcha_v3_site_key_here

# Razorpay Live (server secret — never expose to the browser)
RAZORPAY_KEY_ID=rzp_live_your_key_id
RAZORPAY_KEY_SECRET=your_key_secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_your_key_id

# Optional: Razorpay webhook secret from Dashboard → Webhooks
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# Optional: Firebase service account JSON (single line) for logging payment events to Firestore
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}